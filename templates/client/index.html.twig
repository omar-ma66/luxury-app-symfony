{% extends 'base.html.twig' %}

{% block title %}Client index{% endblock %}

{% block body %}
   
<style>
 
 body{
    
    {# background-color : #000; #}
    background-image : url('{{ asset("assets/img/bg3.jpg")}}');
    background-size:cover;
    background-repeat:no-repeat;
    background-position:0 0;
    background-attachment:fixed;
 }
</style>

            {{ include ('_partials/_header.html.twig')}}
<div class="max-w-7xl mx-auto my-8 p-6 bg-white/60 rounded-xl shadow-sm border border-slate-100 mt-24">
    
    {# En-tête de la page #}
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
        <div>
            <h2 class="text-xl font-bold text-slate-800">Portefeuille Clients</h2>
            <p class="text-sm text-slate-500 mt-1">Liste complète et gestion des fiches clients de la société.</p>
        </div>
        <a href="{{ path('app_client_new') }}" class="inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white text-sm font-medium rounded-lg shadow-sm shadow-indigo-600/10 transition-colors duration-150 cursor-pointer">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Nouveau client
        </a>
    </div>

    {# Conteneur du tableau (Scroll responsive) #}
    <div class="overflow-x-auto rounded-lg border border-slate-100">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50/70 border-b border-slate-100">
                    <th class="px-6 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">ID</th>
                    <th class="px-6 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">Société</th>
                    <th class="px-6 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">Activité</th>
                    <th class="px-6 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">Contact</th>
                    <th class="px-6 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">Coordonnées</th>
                    <th class="px-6 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">Message</th>
                    <th class="px-6 py-3.5 text-xs font-semibold text-slate-500 uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
            {% for client in clients %}
                <tr class="hover:bg-slate-50/50 transition-colors duration-150">
                    {# ID #}
                    <td class="px-6 py-4 text-sm font-medium text-slate-400">
                        #{{ client.id }}
                    </td>
                    
                    {# Nom Société #}
                    <td class="px-6 py-4 text-sm font-semibold text-slate-800">
                        {{ client.nomSociete }}
                    </td>
                    
                    {# Activité #}
                    <td class="px-6 py-4 text-sm text-slate-600">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-slate-100 text-slate-700">
                            {{ client.activite }}
                        </span>
                    </td>
                    
                    {# Contact #}
                    <td class="px-6 py-4 text-sm text-slate-600">
                        <div class="font-medium text-slate-800">{{ client.prenomContact }} {{ client.nomContact }}</div>
                    </td>
                    
                    {# Coordonnées #}
                    <td class="px-6 py-4 text-sm text-slate-500">
                        <div class="flex flex-col gap-0.5">
                            <span class="text-slate-700 font-medium">{{ client.mailContact }}</span>
                            <span class="text-xs text-slate-400">{{ client.telContact }}</span>
                        </div>
                    </td>
                    
                    {# Message #}
                    <td class="px-6 py-4 text-sm text-slate-500 max-w-xs truncate" title="{{ client.messageContact }}">
                        {{ client.messageContact }}
                    </td>
                    
                    {# Actions #}
                    <td class="px-6 py-4 text-sm font-medium text-right whitespace-nowrap">
                        <div class="inline-flex items-center gap-3">
                            <a href="{{ path('app_client_show', {'id': client.id}) }}" class="text-slate-600 hover:text-indigo-600 transition-colors duration-150">
                                Voir
                            </a>
                            <span class="text-slate-200">|</span>
                            <a href="{{ path('app_client_edit', {'id': client.id}) }}" class="text-indigo-600 hover:text-indigo-900 bg-indigo-50 hover:bg-indigo-100/80 px-2.5 py-1 rounded transition-all duration-150">
                                Modifier
                            </a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="px-6 py-12 text-center text-sm text-slate-400 bg-slate-50/30">
                        <svg class="w-10 h-10 mx-auto text-slate-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 00-2 2H6a2 2 0 00-2 2v-5m16 0h-2.586a1 1 0 01-.707-.293l-2.414-2.414a1 1 0 00-.707-.293H13m-1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Aucun client trouvé dans la base de données.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
