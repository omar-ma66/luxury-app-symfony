{% extends 'base.html.twig' %}

{% block title %}New Client{% endblock %}

{% block body %}
   
  
<style>
 
 body{
    
    {# background-color : #000; #}
    background-image : url('{{ asset("assets/img/bg3.jpg")}}');
    background-size:cover;
    background-repeat:no-repeat;
    background-position:0 0;
    background-attachment:fixed;
 }
</style>

     {{ include('_partials/_header.html.twig') }} 


                 {{ form_start(form, {'attr': {'class': 'mt-23 max-w-4xl mx-auto bg-white/60 p-8 rounded-xl shadow-sm border border-slate-100 space-y-8'}}) }}

    {# Section : Informations Entreprise #}
    <div>
        <h3 class="text-lg font-semibold text-slate-800 border-b border-slate-100 pb-2 mb-4">Informations de la Société</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                {{ form_label(form.nomSociete, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-1.5'}}) }}
                {{ form_widget(form.nomSociete, {'attr': {'class': 'w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-800 placeholder-slate-400 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all duration-150 shadow-sm'}}) }}
                <div class="mt-1.5 text-sm text-rose-600">{{ form_errors(form.nomSociete) }}</div>
            </div>                        
            <div> 
                {{ form_label(form.activite, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-1.5'}}) }}
                {{ form_widget(form.activite, {'attr': {'class': 'w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-800 placeholder-slate-400 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all duration-150 shadow-sm'}}) }}
                <div class="mt-1.5 text-sm text-rose-600">{{ form_errors(form.activite) }}</div>
            </div>                        
        </div>
    </div>

    {# Section : Contact Principal #}
    <div>
        <h3 class="text-lg font-semibold text-slate-800 border-b border-slate-100 pb-2 mb-4">Contact Principal</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                {{ form_label(form.nomContact, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-1.5'}}) }}
                {{ form_widget(form.nomContact, {'attr': {'class': 'w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-800 placeholder-slate-400 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all duration-150 shadow-sm'}}) }}
                <div class="mt-1.5 text-sm text-rose-600">{{ form_errors(form.nomContact) }}</div>
            </div>                        
            <div>  
                {{ form_label(form.prenomContact, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-1.5'}}) }}
                {{ form_widget(form.prenomContact, {'attr': {'class': 'w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-800 placeholder-slate-400 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all duration-150 shadow-sm'}}) }}
                <div class="mt-1.5 text-sm text-rose-600">{{ form_errors(form.prenomContact) }}</div>
            </div>                        
            <div>
                {{ form_label(form.mailContact, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-1.5'}}) }}
                {{ form_widget(form.mailContact, {'attr': {'class': 'w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-800 placeholder-slate-400 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all duration-150 shadow-sm'}}) }}
                <div class="mt-1.5 text-sm text-rose-600">{{ form_errors(form.mailContact) }}</div>
            </div>                        
            <div>
                {{ form_label(form.telContact, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-1.5'}}) }}
                {{ form_widget(form.telContact, {'attr': {'class': 'w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-800 placeholder-slate-400 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all duration-150 shadow-sm'}}) }}
                <div class="mt-1.5 text-sm text-rose-600">{{ form_errors(form.telContact) }}</div>
            </div>                        
        </div>
    </div>
    

    {# Section : Message #}
    <div class="border-t border-slate-100 pt-6">
        {{ form_label(form.messageContact, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-1.5'}}) }}
        {{ form_widget(form.messageContact, {'attr': {'class': 'w-full px-4 py-2.5 rounded-lg border border-slate-300 text-slate-800 placeholder-slate-400 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all duration-150 shadow-sm min-h-[120px]'}}) }}
        <div class="mt-1.5 text-sm text-rose-600">{{ form_errors(form.messageContact) }}</div>
    </div>                        

    {# Actions du bas #}
    <div class="flex flex-col sm:flex-row-reverse items-center justify-between gap-4 pt-4 border-t border-slate-100">
        <button class="w-full sm:w-auto px-6 py-2.5 rounded-lg bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white font-medium shadow-sm shadow-indigo-600/10 transition-colors duration-150 text-sm cursor-pointer">
            Enregistrer le client
        </button>
        <a href="{{ path('app_client_index') }}" class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-slate-800 transition-colors duration-150 group">
            <svg class="w-4 h-4 mr-2 transform group-hover:-translate-x-0.5 transition-transform duration-150" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Retour à la liste
        </a>
    </div>

{{ form_end(form) }}
     {{ include('_partials/_footer.html.twig') }} 

{% endblock %}
