{% extends 'base.html.twig' %}

{% block title %}Client{% endblock %}

{% block body %}
    <h1>Client</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ client.id }}</td>
            </tr>
            <tr>
                <th>NomSociete</th>
                <td>{{ client.nomSociete }}</td>
            </tr>
            <tr>
                <th>Activite</th>
                <td>{{ client.activite }}</td>
            </tr>
            <tr>
                <th>NomContact</th>
                <td>{{ client.nomContact }}</td>
            </tr>
            <tr>
                <th>PrenomContact</th>
                <td>{{ client.prenomContact }}</td>
            </tr>
            <tr>
                <th>MailContact</th>
                <td>{{ client.mailContact }}</td>
            </tr>
            <tr>
                <th>TelContact</th>
                <td>{{ client.telContact }}</td>
            </tr>
            <tr>
                <th>MessageContact</th>
                <td>{{ client.messageContact }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_client_index') }}">back to list</a>

    <a href="{{ path('app_client_edit', {'id': client.id}) }}">edit</a>

    {{ include('client/_delete_form.html.twig') }}
{% endblock %}
