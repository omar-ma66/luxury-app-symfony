{% extends 'base.html.twig' %}

{% block title %}Client{% endblock %}

{% block body %}
      
<style>
 
 body{
    
    {# background-color : #000; #}
    background-image : url('{{ asset("assets/img/bg3.jpg")}}');
    background-size:cover;
    background-repeat:no-repeat;
    background-position:0 0;
    background-attachment:fixed;
 }
</style>


<div class="max-w-4xl mx-auto my-8 p-6 bg-white rounded-2xl shadow-xl border border-slate-100 font-sans">
    
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center pb-6 mb-6 border-b border-slate-100 gap-4">
        <div>
            <span class="text-xs font-semibold uppercase tracking-wider text-indigo-600 bg-indigo-50 px-3 py-1 rounded-full">
                Fiche Client VIP
            </span>
            <h1 class="text-3xl font-bold text-slate-800 mt-2">{{ client.nomSociete }}</h1>
            <p class="text-sm text-slate-500 mt-1">Secteur d'activité : <span class="font-medium text-slate-700">{{ client.activite }}</span></p>
        </div>
        
        <div class="text-xs text-slate-400 bg-slate-50 px-3 py-1.5 rounded-md border border-slate-200">
            ID Client : <span class="font-mono font-bold text-slate-700">#{{ client.id }}</span>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        
        <div class="p-5 bg-slate-50 rounded-xl border border-slate-100">
            <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-4">Interlocuteur Principal</h3>
            <div class="space-y-3">
                <div>
                    <label class="text-xs text-slate-400 block">Nom complet</label>
                    <span class="text-sm font-semibold text-slate-800">{{ client.prenomContact }} {{ client.nomContact }}</span>
                </div>
                <div>
                    <label class="text-xs text-slate-400 block">Adresse Email</label>
                    <a href="mailto:{{ client.mailContact }}" class="text-sm font-medium text-indigo-600 hover:underline flex items-center gap-1">
                        {{ client.mailContact }}
                    </a>
                </div>
                <div>
                    <label class="text-xs text-slate-400 block">Téléphone direct</label>
                    <a href="tel:{{ client.telContact }}" class="text-sm font-medium text-slate-700 hover:text-indigo-600 transition-colors">
                        {{ client.telContact }}
                    </a>
                </div>
            </div>
        </div>

        <div class="p-5 bg-slate-50 rounded-xl border border-slate-100 flex flex-col justify-between">
            <div>
                <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-3">Note ou Message de contact</h3>
                <div class="text-sm text-slate-600 bg-white p-3 rounded-lg border border-slate-200 italic min-h-[80px]">
                    "{{ client.messageContact }}"
                </div>
            </div>
        </div>

    </div>

    <div class="flex flex-col sm:flex-row justify-between items-center pt-6 border-t border-slate-100 gap-4">
        
        <a href="{{ path('app_client_index') }}" class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-slate-800 transition-colors gap-2 group order-3 sm:order-1">
            <svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Retour à la liste
        </a>

        <div class="flex items-center gap-3 w-full sm:w-auto justify-end order-1 sm:order-2">
            
            <a href="{{ path('app_client_edit', {'id': client.id}) }}" class="inline-flex justify-center items-center px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-xl shadow-sm hover:shadow transition-all w-full sm:w-auto text-center">
                Modifier la fiche
            </a>

            <form method="post" action="{{ path('app_client_delete', {'id': client.id}) }}" onsubmit="return confirm('Êtes-vous absolument sûr de vouloir supprimer ce client de haute importance ?');" class="w-full sm:w-auto">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ client.id) }}">
                <button class="inline-flex justify-center items-center px-5 py-2.5 border border-transparent hover:border-red-200 bg-red-50 hover:bg-red-100 text-red-600 hover:text-red-700 text-sm font-medium rounded-xl transition-all w-full sm:w-auto text-center">
                    Supprimer
                </button>
            </form>
            
        </div>
    </div>
</div>

    {# {{ include('client/_delete_form.html.twig') }} #}
{% endblock %}
