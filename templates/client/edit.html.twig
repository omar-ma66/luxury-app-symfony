{% extends 'base.html.twig' %}

{% block title %}Edit Client{% endblock %}




{% block body %}
  
<style>
 
 body{
  
    background-image : url('{{ asset("assets/img/bg3.jpg")}}');
    background-size:cover;
    background-repeat:no-repeat;
    background-position:0 0;
    background-attachment:fixed;
 }
</style>

{{ include('_partials/_header.html.twig')}}

{{ form_start(form, {'attr': {'class': 'mt-25 max-w-4xl mx-auto bg-white/50 p-8 md:p-10 rounded-2xl shadow-xl border border-slate-100/80 space-y-10'}}) }}

    {# En-tête du Formulaire (Pour marquer l'importance) #}
    <div class="border-b border-slate-100 pb-5">
        <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Fiche Client Privilégié</h2>
        <p class="text-sm text-slate-500 mt-1">Veuillez renseigner et vérifier soigneusement les informations ci-dessous.</p>
    </div>

    {# Section : Informations Entreprise #}
    <div class="space-y-6">
        <div class="flex items-center space-x-2 border-b border-slate-100 pb-2">
            <span class="flex h-2 w-2 rounded-full bg-indigo-600"></span>
            <h3 class="text-lg font-bold text-slate-800">Informations de la Société</h3>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                {{ form_label(form.nomSociete, null, {'label_attr': {'class': 'block text-sm font-bold text-slate-900 mb-2'}}) }}
                {{ form_widget(form.nomSociete, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 text-slate-800 placeholder-slate-400 focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 transition-all duration-200 shadow-sm bg-slate-50/30'}}) }}
                <div class="mt-1.5 text-xs font-medium text-rose-600 flex items-center">{{ form_errors(form.nomSociete) }}</div>
            </div>                        
            <div> 
                {{ form_label(form.activite, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
                {{ form_widget(form.activite, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 text-slate-800 placeholder-slate-400 focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 transition-all duration-200 shadow-sm bg-slate-50/30'}}) }}
                <div class="mt-1.5 text-xs font-medium text-rose-600 flex items-center">{{ form_errors(form.activite) }}</div>
            </div>                        
        </div>
    </div>

    {# Section : Contact Principal #}
    <div class="space-y-6">
        <div class="flex items-center space-x-2 border-b border-slate-100 pb-2">
            <span class="flex h-2 w-2 rounded-full bg-indigo-600"></span>
            <h3 class="text-lg font-semibold text-slate-800">Contact Principal</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                {{ form_label(form.nomContact, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
                {{ form_widget(form.nomContact, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 text-slate-800 placeholder-slate-400 focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 transition-all duration-200 shadow-sm bg-slate-50/30'}}) }}
                <div class="mt-1.5 text-xs font-medium text-rose-600 flex items-center">{{ form_errors(form.nomContact) }}</div>
            </div>                        
            <div>  
                {{ form_label(form.prenomContact, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
                {{ form_widget(form.prenomContact, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 text-slate-800 placeholder-slate-400 focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 transition-all duration-200 shadow-sm bg-slate-50/30'}}) }}
                <div class="mt-1.5 text-xs font-medium text-rose-600 flex items-center">{{ form_errors(form.prenomContact) }}</div>
            </div>                        
            <div>
                {{ form_label(form.mailContact, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
                {{ form_widget(form.mailContact, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 text-slate-800 placeholder-slate-400 focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 transition-all duration-200 shadow-sm bg-slate-50/30'}}) }}
                <div class="mt-1.5 text-xs font-medium text-rose-600 flex items-center">{{ form_errors(form.mailContact) }}</div>
            </div>                        
            <div>
                {{ form_label(form.telContact, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
                {{ form_widget(form.telContact, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 text-slate-800 placeholder-slate-400 focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 transition-all duration-200 shadow-sm bg-slate-50/30'}}) }}
                <div class="mt-1.5 text-xs font-medium text-rose-600 flex items-center">{{ form_errors(form.telContact) }}</div>
            </div>                        
        </div>
    </div>

    {# Section : Message / Notes #}
    <div class="space-y-4 pt-2">
        {{ form_label(form.messageContact, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
        {{ form_widget(form.messageContact, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 text-slate-800 placeholder-slate-400 focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 transition-all duration-200 shadow-sm bg-slate-50/30 min-h-[140px] resize-y'}}) }}
        <div class="mt-1.5 text-xs font-medium text-rose-600 flex items-center">{{ form_errors(form.messageContact) }}</div>
    </div>                        

    {# Actions du bas #}
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-6 border-t border-slate-100">
        
        {# Gauche : Retour #}
        <a href="{{ path('app_client_index') }}" class="w-full sm:w-auto inline-flex items-center justify-center text-sm font-medium text-slate-500 hover:text-slate-800 transition-colors duration-150 group py-2.5">
            <svg class="w-4 h-4 mr-2 transform group-hover:-translate-x-1 transition-transform duration-150" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Retour à la liste
        </a>

        {# Droite : Actions principales #}
        <div class="flex flex-col-reverse sm:flex-row items-center gap-3 w-full sm:w-auto">
            {# Formulaire de suppression élégant #}
            <button type="submit" form="delete-form-{{ client.id }}" class="w-full sm:w-auto px-5 py-2.5 rounded-xl border border-rose-200 hover:border-rose-300 bg-rose-50/50 hover:bg-rose-50 text-rose-600 font-medium transition-all duration-150 text-sm cursor-pointer text-center">
                Supprimer la fiche
            </button>

            {# Bouton Enregistrer #}
            <button type="submit" class="w-full sm:w-auto px-6 py-2.5 rounded-xl bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white font-semibold shadow-md shadow-indigo-600/10 hover:shadow-indigo-600/20 transition-all duration-150 text-sm cursor-pointer text-center">
                Enregistrer le client
            </button>
        </div>
    </div>

{{ form_end(form) }}

{# Formulaire de suppression déporté (pour respecter la validité HTML) #}
<form id="delete-form-{{ client.id }}" method="post" action="{{ path('app_client_delete', {'id': client.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer définitivement ce client important ?');" class="hidden">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ client.id) }}">
</form>

{{ include('_partials/_footer.html.twig')}}

{% endblock %}