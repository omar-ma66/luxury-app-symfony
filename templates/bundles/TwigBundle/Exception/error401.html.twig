{# templates/bundles/TwigBundle/Exception/error401.html.twig #}
<!DOCTYPE html>
<html lang="fr" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Authentification requise - 401</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="flex h-full flex-col bg-slate-50 font-sans text-slate-900 antialiased dark:bg-slate-900 dark:text-slate-100">

    <main class="mx-auto flex w-full max-w-7xl flex-grow flex-col justify-center px-6 lg:px-8">
        
        <div class="flex flex-col items-center text-center">
            <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-sky-50 text-sky-600 dark:bg-sky-950/50 dark:text-sky-400">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z" />
                </svg>
            </div>
            
            <p class="mt-4 text-base font-semibold tracking-wide text-sky-600 dark:text-sky-400 uppercase">Erreur 401</p>
            <h1 class="mt-2 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl dark:text-white">Authentification requise</h1>
            <p class="mt-4 max-w-md text-base leading-7 text-slate-600 dark:text-slate-400">
                Tu dois être connecté pour accéder à cette page. Identifie-toi pour continuer ou retourne à la page d'accueil.
            </p>
        </div>

        <div class="mt-10 flex items-center justify-center gap-x-6">
            <a href="{{ path('app_login') }}" class="rounded-lg bg-sky-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-sky-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-600 transition-colors duration-200">
                Se connecter
            </a>
            
            <a href="{{ path('app_home') }}" class="group text-sm font-semibold text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white flex items-center gap-1">
                Retour à l'accueil
                <span class="inline-block transition-transform group-hover:translate-x-1" aria-hidden="true">&rarr;</span>
            </a>
        </div>

        <div class="mx-auto mt-16 w-full max-w-2xl border-t border-slate-200 pt-8 dark:border-slate-800">
            <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400 text-center">Pas encore de compte ?</h2>
            <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
                
                <div class="relative flex items-center space-x-3 rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-950">
                    <div class="flex-shrink-0 text-slate-400">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0ZM3 19.235v-.111a6.375 6.375 0 0 1 12.75 0v.111c0 .492-.4.894-.893.894H3.893A.894.894 0 0 1 3 19.235Z" />
                        </svg>
                    </div>
                    <div class="min-w-0 flex-1">
                        {# Remplace 'app_register' par ta route d'inscription si tu en as une #}
                        <a href="/register" class="focus:outline-none">
                            <span class="absolute inset-0" aria-hidden="true"></span>
                            <p class="text-sm font-medium text-slate-900 dark:text-white">S'inscrire</p>
                            <p class="text-xs text-slate-500 dark:text-slate-400 truncate">Créer un compte en quelques clics.</p>
                        </a>
                    </div>
                </div>

                <div class="relative flex items-center space-x-3 rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-950">
                    <div class="flex-shrink-0 text-slate-400">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
                        </svg>
                    </div>
                    <div class="min-w-0 flex-1">
                        <a href="/contact" class="focus:outline-none">
                            <span class="absolute inset-0" aria-hidden="true"></span>
                            <p class="text-sm font-medium text-slate-900 dark:text-white">Assistance</p>
                            <p class="text-xs text-slate-500 dark:text-slate-400 truncate">Un problème avec tes identifiants ?</p>
                        </a>
                    </div>
                </div>
                
            </div>
        </div>
        
    </main>

    <footer class="mx-auto w-full max-w-7xl flex-shrink-0 px-6 py-4 lg:px-8 text-center text-xs text-slate-400 dark:text-slate-500">
        &copy; {{ "now"|date("Y") }} Votre Entreprise. Tous droits réservés.
    </footer>

</body>
</html>