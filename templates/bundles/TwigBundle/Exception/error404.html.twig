{# templates/bundles/TwigBundle/Exception/error404.html.twig #}
<!DOCTYPE html>
<html lang="fr" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Page non trouvée - 404</title>
    <!-- Tailwind CSS pour un rendu pro et rapide -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="flex h-full flex-col bg-slate-50 font-sans text-slate-900 antialiased dark:bg-slate-900 dark:text-slate-100">

    <main class="mx-auto flex w-full max-w-7xl flex-grow flex-col justify-center px-6 lg:px-8">
        
        <!-- Illustration / Badge 404 Épuré -->
        <div class="flex flex-col items-center text-center">
            <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-indigo-50 text-indigo-600 dark:bg-indigo-950/50 dark:text-indigo-400">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
                </svg>
            </div>
            
            <p class="mt-4 text-base font-semibold tracking-wide text-indigo-600 dark:text-indigo-400 uppercase">Erreur 404</p>
            <h1 class="mt-2 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl dark:text-white">Page introuvable</h1>
            <p class="mt-4 max-w-md text-base leading-7 text-slate-600 dark:text-slate-400">
                Désolé, la page que tu recherches n'existe pas ou a été déplacée. Vérifie l'adresse URL ou utilise les liens ci-dessous.
            </p>
        </div>

        <!-- Liens d'action professionnels -->
        <div class="mt-10 flex items-center justify-center gap-x-6">
            <!-- Retour à l'accueil de ton app Symfony -->
            <a href="{{ path('app_home') }}" class="rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-colors duration-200">
                Retour à l'accueil
            </a>
            
            <!-- Lien secondaire (ex: Contact / Support) -->
            <a href="/contact" class="group text-sm font-semibold text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white flex items-center gap-1">
                Contacter le support 
                <span class="inline-block transition-transform group-hover:translate-x-1" aria-hidden="true">&rarr;</span>
            </a>
        </div>

        <!-- Petite section d'aide supplémentaire (Optionnelle mais très pro) -->
        <div class="mx-auto mt-16 w-full max-w-2xl border-t border-slate-200 pt-8 dark:border-slate-800">
            <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400 text-center">Besoin d'aide immédiate ?</h2>
            <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div class="relative flex items-center space-x-3 rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-950">
                    <div class="flex-shrink-0 text-slate-400">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                        </svg>
                    </div>
                    <div class="min-w-0 flex-1">
                        <a href="/docs" class="focus:outline-none">
                            <span class="absolute inset-0" aria-hidden="true"></span>
                            <p class="text-sm font-medium text-slate-900 dark:text-white">Documentation</p>
                            <p class="text-xs text-slate-500 dark:text-slate-400 truncate">Consulter nos guides et tutoriels.</p>
                        </a>
                    </div>
                </div>

                <div class="relative flex items-center space-x-3 rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-950">
                    <div class="flex-shrink-0 text-slate-400">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 21L14.907 18M21.907 18 21 21l-5.908-3m.001-9.448a4.478 4.478 0 1 1-8.955 0 4.478 4.478 0 0 1 8.955 0Z" />
                        </svg>
                    </div>
                    <div class="min-w-0 flex-1">
                        <a href="/status" class="focus:outline-none">
                            <span class="absolute inset-0" aria-hidden="true"></span>
                            <p class="text-sm font-medium text-slate-900 dark:text-white">État des services</p>
                            <p class="text-xs text-slate-500 dark:text-slate-400 truncate">Vérifier si une panne est en cours.</p>
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
    </main>

    <!-- Footer minimaliste -->
    <footer class="mx-auto w-full max-w-7xl flex-shrink-0 px-6 py-4 lg:px-8 text-center text-xs text-slate-400 dark:text-slate-500">
        &copy; {{ "now"|date("Y") }} Votre Entreprise. Tous droits réservés.
    </footer>

</body>
</html>