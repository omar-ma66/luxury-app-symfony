{# templates/bundles/TwigBundle/Exception/error403.html.twig #}
<!DOCTYPE html>
<html lang="fr" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Accès refusé - 403</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="flex h-full flex-col bg-slate-50 font-sans text-slate-900 antialiased dark:bg-slate-900 dark:text-slate-100">

    <main class="mx-auto flex w-full max-w-7xl flex-grow flex-col justify-center px-6 lg:px-8">
        
        <div class="flex flex-col items-center text-center">
            <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-amber-50 text-amber-600 dark:bg-amber-950/50 dark:text-amber-400">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                </svg>
            </div>
            
            <p class="mt-4 text-base font-semibold tracking-wide text-amber-600 dark:text-amber-400 uppercase">Erreur 403</p>
            <h1 class="mt-2 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl dark:text-white">Accès restreint</h1>
            <p class="mt-4 max-w-md text-base leading-7 text-slate-600 dark:text-slate-400">
                Tu n'as pas les autorisations nécessaires pour accéder à cette page. Si tu penses qu'il s'agit d'une erreur, contacte l'administrateur.
            </p>
        </div>

        <div class="mt-10 flex items-center justify-center gap-x-6">
            <a href="{{ path('app_home') }}" class="rounded-lg bg-amber-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-amber-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-600 transition-colors duration-200">
                Retour à l'accueil
            </a>
            
            <a href="/contact" class="group text-sm font-semibold text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white flex items-center gap-1">
                Contacter le support 
                <span class="inline-block transition-transform group-hover:translate-x-1" aria-hidden="true">&rarr;</span>
            </a>
        </div>

        <div class="mx-auto mt-16 w-full max-w-2xl border-t border-slate-200 pt-8 dark:border-slate-800">
            <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400 text-center">Que faire maintenant ?</h2>
            <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
                
                <div class="relative flex items-center space-x-3 rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-950">
                    <div class="flex-shrink-0 text-slate-400">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                        </svg>
                    </div>
                    <div class="min-w-0 flex-1">
                        <a href="{{ path('app_login') }}" class="focus:outline-none">
                            <span class="absolute inset-0" aria-hidden="true"></span>
                            <p class="text-sm font-medium text-slate-900 dark:text-white">Se connecter</p>
                            <p class="text-xs text-slate-500 dark:text-slate-400 truncate">Utiliser un compte avec plus de privilèges.</p>
                        </a>
                    </div>
                </div>

                <div class="relative flex items-center space-x-3 rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-950">
                    <div class="flex-shrink-0 text-slate-400">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
                        </svg>
                    </div>
                    <div class="min-w-0 flex-1">
                        <a href="#" onclick="window.history.back(); return false;" class="focus:outline-none">
                            <span class="absolute inset-0" aria-hidden="true"></span>
                            <p class="text-sm font-medium text-slate-900 dark:text-white">Page précédente</p>
                            <p class="text-xs text-slate-500 dark:text-slate-400 truncate">Faire marche arrière en toute sécurité.</p>
                        </a>
                    </div>
                </div>
                
            </div>
        </div>
        
    </main>

    <footer class="mx-auto w-full max-w-7xl flex-shrink-0 px-6 py-4 lg:px-8 text-center text-xs text-slate-400 dark:text-slate-500">
        &copy; {{ "now"|date("Y") }} Votre Entreprise. Tous droits réservés.
    </footer>

</body>
</html>