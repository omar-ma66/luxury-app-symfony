{% extends 'base.html.twig' %}

{% block title %}Gestion des Candidats{% endblock %}

{% block body %}

<style>
body{
    background-image:url('{{asset("assets/img/bg2.jpg")}}');
    background-position:center;
    background-size:cover;
    background-repeat:no-repeat;
    background-attachment: fixed; 
} 

</style>


{{ include ('_partials/_header.html.twig')}}

{# <script src="https://cdn.tailwindcss.com"></script> #}

<div class=" mt-20 max-w-7xl mx-auto px-4 py-8 antialiased text-gray-800">
    
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <div>
            <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">Liste des Candidats</h1>
            <p class="text-sm text-slate-500 mt-1">Consultez, modifiez et gérez les profils des candidats de la plateforme.</p>
        </div>
        <div>
            <a href="{{ path('app_candidat_new') }}" class="inline-flex items-center justify-center px-4 py-2.5 border border-transparent rounded-xl text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 shadow-sm transition-all duration-200 group">
                <svg class="w-4 h-4 mr-2 text-indigo-200 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Ajouter un candidat
            </a>
        </div>
    </div>

    <div class="bg-white/80 rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/70 border-b border-slate-100">
                        <th class="py-4 px-6 text-xs font-bold text-slate-400 uppercase tracking-wider w-16">ID</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-400 uppercase tracking-wider">Candidat</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-400 uppercase tracking-wider">Contact</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-400 uppercase tracking-wider">Localisation</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-400 uppercase tracking-wider">Poste & Exp.</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-400 uppercase tracking-wider">Profil</th>
                        <th class="py-4 px-6 text-xs font-bold text-slate-400 uppercase tracking-wider text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                {% for candidat in candidats %}
                    <tr class="hover:bg-slate-50/50 transition-colors duration-150">
                        <td class="py-4 px-6 text-sm font-medium text-slate-400">
                            #{{ candidat.id }}
                        </td>
                        
                        <td class="py-4 px-6">
                            <div class="font-semibold text-slate-900">{{ candidat.prenom }} {{ candidat.nom }}</div>
                            <div class="text-xs text-slate-400 mt-0.5">{{ candidat.genre|default('Non spécifié') }}</div>
                        </td>
                        
                        <td class="py-4 px-6 text-sm text-slate-600">
                            <span class="block max-w-[180px] truncate" title="{{ candidat.mail }}">{{ candidat.mail }}</span>
                        </td>
                        
                        <td class="py-4 px-6 text-sm text-slate-600">
                            <div class="font-medium text-slate-800">{{ candidat.pays }}</div>
                            <div class="text-xs text-slate-400 truncate max-w-[150px]" title="{{ candidat.adresse }}">{{ candidat.adresse }}</div>
                        </td>
                        
                        <td class="py-4 px-6">
                            <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-indigo-50 text-indigo-700 mb-1">
                                {{ candidat.jobCategorie|default('Général') }}
                            </span>
                            <div class="text-xs text-slate-500 font-medium">{{ candidat.experience }} ans d'exp.</div>
                        </td>
                        
                        <td class="py-4 px-6 text-xs text-slate-500 space-y-0.5">
                            <div><span class="text-slate-400">Né le :</span> {{ candidat.naissance ? candidat.naissance|date('d/m/Y') : '-' }}</div>
                            <div class="truncate max-w-[120px]"><span class="text-slate-400">À :</span> {{ candidat.lieuNaissance }}</div>
                            <div class="truncate max-w-[120px]"><span class="text-slate-400">Nat :</span> {{ candidat.nationalite }}</div>
                        </td>
                        
                        <td class="py-4 px-6 text-right space-x-1 whitespace-nowrap">
                            <a href="{{ path('app_candidat_show', {'id': candidat.id}) }}" class="inline-flex items-center px-3 py-1.5 border border-slate-200 rounded-lg text-xs font-semibold text-slate-700 bg-white hover:bg-slate-50 transition-colors shadow-sm">
                                Voir
                            </a>
                            <a href="{{ path('app_candidat_edit', {'id': candidat.id}) }}" class="inline-flex items-center px-3 py-1.5 border border-transparent rounded-lg text-xs font-semibold text-white bg-slate-800 hover:bg-slate-900 transition-colors shadow-sm">
                                Modifier
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="py-12 px-6 text-center">
                            <div class="max-w-sm mx-auto">
                                <svg class="mx-auto h-12 w-12 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                                </svg>
                                <h3 class="mt-4 text-sm font-semibold text-slate-900">Aucun candidat</h3>
                                <p class="mt-1 text-xs text-slate-500">La base de données ne contient aucun profil pour le moment.</p>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{{ include('_partials/_footer.html.twig')}}
{% endblock %}