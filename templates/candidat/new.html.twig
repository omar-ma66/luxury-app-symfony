{% extends 'base.html.twig' %}

{% block title %}Édition Candidat Intel
{% endblock %}

{% block body %}


	<style>
		body {
			background-image: url('{{asset("assets/img/bg2.jpg")}}');
			background-position: center;
			background-size: cover;
			background-repeat: no-repeat;
			background-attachment: fixed;
		}
	</style>


	{{ include ('_partials/_header.html.twig')}}

	{# <script src="https://cdn.tailwindcss.com"></script> #}

	<div class="mt-20 max-w-4xl mx-auto px-4 py-8 antialiased text-gray-800">

		<div class="mb-6">
			<a href="{{ path('app_candidat_index') }}" class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-slate-800 transition-colors duration-200">
				<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewbox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
				</svg>
				Retour à la liste
			</a>
		</div>

		<div class="bg-white/80 rounded-2xl shadow-sm border border-slate-100 overflow-hidden">

			<div class="p-6 sm:p-8 bg-slate-50 border-b border-slate-100">
				<h1 class="text-2xl font-bold text-slate-900 tracking-tight">Fiche Informations Candidat</h1>
				<p class="text-sm text-slate-500 mt-1">Renseignez le profil candidat avec précision pour l'évaluation.</p>
			</div>

			{{ form_start(form) }}
			<div class="p-6 sm:p-8 space-y-8">

				<div>
					<h2 class="text-xs font-bold text-indigo-600 uppercase tracking-wider mb-4">1. Identité & État Civil</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
						<div>
							{{ form_label(form.nom, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.nom) }}
						</div>
						<div>
							{{ form_label(form.prenom, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.prenom) }}
						</div>
						<div>
							{{ form_label(form.genre, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.genre) }}
						</div>
						<div>
							{{ form_label(form.naissance, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.naissance) }}
						</div>
						<div>
							{{ form_label(form.lieuNaissance, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.lieuNaissance) }}
						</div>
						<div>
							{{ form_label(form.nationalite, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.nationalite) }}
						</div>
					</div>
				</div>

				<hr class="border-slate-100">

				<div>
					<h2 class="text-xs font-bold text-indigo-600 uppercase tracking-wider mb-4">2. Coordonnées de Contact</h2>
					<div class="grid grid-cols-1 md:grid-cols-3 gap-5">
						<div class="md:col-span-3">
							{{ form_label(form.mail, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.mail) }}
						</div>
						<div class="md:col-span-2">
							{{ form_label(form.adresse, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.adresse) }}
						</div>
						<div>
							{{ form_label(form.pays, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.pays) }}
						</div>
					</div>
				</div>

				<hr class="border-slate-100">

				<div>
					<h2 class="text-xs font-bold text-indigo-600 uppercase tracking-wider mb-4">3. Profil Spécifique</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
						<div>
							{{ form_label(form.jobCategorie, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.jobCategorie) }}
						</div>
						<div>
							{{ form_label(form.experience, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.experience) }}
						</div>
					</div>
					<div>
						{{ form_label(form.description, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
						{{ form_widget(form.description) }}
					</div>
				</div>

				<div class="pt-4 border-t border-slate-100 flex items-center justify-end gap-3">
					<a href="{{ path('app_candidat_index') }}" class="px-5 py-2.5 border border-slate-200 rounded-xl text-sm font-semibold text-slate-600 bg-white hover:bg-slate-50 transition-all">
						Annuler
					</a>
					<button type="submit" class="px-6 py-2.5 border border-transparent rounded-xl text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 shadow-sm transition-all">
						Confirmer les modifications
					</button>
				</div>

			</div>
			{{ form_end(form) }}
		</div>
	</div>
	{{ include ('_partials/_footer.html.twig')}}
{% endblock %}
