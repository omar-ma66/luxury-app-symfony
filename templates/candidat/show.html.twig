{% extends 'base.html.twig' %}

{% block title %}Candidat{% endblock %}

{% block body %}
    <h1>Candidat</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ candidat.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ candidat.nom }}</td>
            </tr>
            <tr>
                <th>Prenom</th>
                <td>{{ candidat.prenom }}</td>
            </tr>
            <tr>
                <th>Adresse</th>
                <td>{{ candidat.adresse }}</td>
            </tr>
            <tr>
                <th>Pays</th>
                <td>{{ candidat.pays }}</td>
            </tr>
            <tr>
                <th>Nationalite</th>
                <td>{{ candidat.nationalite }}</td>
            </tr>
            <tr>
                <th>Naissance</th>
                <td>{{ candidat.naissance ? candidat.naissance|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>LieuNaissance</th>
                <td>{{ candidat.lieuNaissance }}</td>
            </tr>
            <tr>
                <th>Mail</th>
                <td>{{ candidat.mail }}</td>
            </tr>
            <tr>
                <th>JobCategorie</th>
                <td>{{ candidat.jobCategorie }}</td>
            </tr>
            <tr>
                <th>Experience</th>
                <td>{{ candidat.experience }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ candidat.description }}</td>
            </tr>
            <tr>
                <th>Genre</th>
                <td>{{ candidat.genre }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_candidat_index') }}">back to list</a>

    <a href="{{ path('app_candidat_edit', {'id': candidat.id}) }}">edit</a>

    {{ include('candidat/_delete_form.html.twig') }}
{% endblock %}
