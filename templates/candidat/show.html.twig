{# {% extends 'base.html.twig' %}

{% block title %}Candidat{% endblock %}

{% block body %}
    <h1>Candidat</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ candidat.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ candidat.nom }}</td>
            </tr>
            <tr>
                <th>Prenom</th>
                <td>{{ candidat.prenom }}</td>
            </tr>
            <tr>
                <th>Adresse</th>
                <td>{{ candidat.adresse }}</td>
            </tr>
            <tr>
                <th>Pays</th>
                <td>{{ candidat.pays }}</td>
            </tr>
            <tr>
                <th>Nationalite</th>
                <td>{{ candidat.nationalite }}</td>
            </tr>
            <tr>
                <th>Naissance</th>
                <td>{{ candidat.naissance ? candidat.naissance|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>LieuNaissance</th>
                <td>{{ candidat.lieuNaissance }}</td>
            </tr>
            <tr>
                <th>Mail</th>
                <td>{{ candidat.mail }}</td>
            </tr>
            <tr>
                <th>JobCategorie</th>
                <td>{{ candidat.jobCategorie }}</td>
            </tr>
            <tr>
                <th>Experience</th>
                <td>{{ candidat.experience }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ candidat.description }}</td>
            </tr>
            <tr>
                <th>Genre</th>
                <td>{{ candidat.genre }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_candidat_index') }}">back to list</a>

    <a href="{{ path('app_candidat_edit', {'id': candidat.id}) }}">edit</a>

    {{ include('candidat/_delete_form.html.twig') }}
{% endblock %} #}


{% extends 'base.html.twig' %}

{% block title %}Profil Candidat -
	{{ candidat.prenom }}
	{{ candidat.nom }}
{% endblock %}

{% block body %}

	<style>
		body {
			background-image: url('{{asset("assets/img/bg2.jpg")}}');
			background-position: center;
			background-size: cover;
			background-repeat: no-repeat;
			background-attachment: fixed;
		}
	</style>


	{{ include ('_partials/_header.html.twig')}}

	<script src="https://cdn.tailwindcss.com"></script>

	<div class="max-w-5xl mx-auto px-4 py-8 antialiased text-gray-800">

		<div class="mb-6">
			<a href="{{ path('app_candidat_index') }}" class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-slate-800 transition-colors duration-200">
				<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewbox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
				</svg>
				Retour à la liste
			</a>
		</div>

		<div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">

			<div class="p-6 sm:p-8 bg-slate-50 border-b border-slate-100 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
				<div>
					<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700 mb-2">
						ID: #{{ candidat.id }}
					</span>
					<h1 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">
						{{ candidat.prenom }}
						{{ candidat.nom }}
					</h1>
					<p class="text-sm text-slate-500 mt-1 flex items-center">
						<svg class="w-4 h-4 mr-1 text-slate-400" fill="none" stroke="currentColor" viewbox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
						</svg>
						{{ candidat.jobCategorie|default('Non spécifié') }}
					</p>
				</div>

				<div class="flex items-center gap-3 w-full sm:w-auto">
					<a href="{{ path('app_candidat_edit', {'id': candidat.id}) }}" class="flex-1 sm:flex-none inline-flex justify-center items-center px-4 py-2 border border-slate-200 rounded-xl text-sm font-semibold text-slate-700 bg-white hover:bg-slate-50 hover:border-slate-300 shadow-sm transition-all duration-200">
						<svg class="w-4 h-4 mr-2 text-slate-500" fill="none" stroke="currentColor" viewbox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
						</svg>
						Modifier
					</a>
					<div class="flex-1 sm:flex-none">
						{{ include('candidat/_delete_form.html.twig') }}
					</div>
				</div>
			</div>

			<div class="p-6 sm:p-8 space-y-8">

				<div>
					<h2 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4">Informations Personnelles</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
						<div>
							<label class="block text-xs font-medium text-slate-400">Genre</label>
							<p class="mt-1 text-sm font-semibold text-slate-800">{{ candidat.genre|default('-') }}</p>
						</div>
						<div>
							<label class="block text-xs font-medium text-slate-400">Date de naissance</label>
							<p class="mt-1 text-sm font-semibold text-slate-800">
								{{ candidat.naissance ? candidat.naissance|date('d/m/Y') : '-' }}
							</p>
						</div>
						<div>
							<label class="block text-xs font-medium text-slate-400">Lieu de naissance</label>
							<p class="mt-1 text-sm font-semibold text-slate-800">{{ candidat.lieuNaissance|default('-') }}</p>
						</div>
						<div>
							<label class="block text-xs font-medium text-slate-400">Nationalité</label>
							<p class="mt-1 text-sm font-semibold text-slate-800">{{ candidat.nationalite|default('-') }}</p>
						</div>
						<div>
							<label class="block text-xs font-medium text-slate-400">Pays actuel</label>
							<p class="mt-1 text-sm font-semibold text-slate-800">{{ candidat.pays|default('-') }}</p>
						</div>
						<div>
							<label class="block text-xs font-medium text-slate-400">Adresse résidentielle</label>
							<p class="mt-1 text-sm font-semibold text-slate-800">{{ candidat.adresse|default('-') }}</p>
						</div>
					</div>
				</div>

				<hr class="border-slate-100">

				<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
					<div>
						<h2 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4">Contact</h2>
						<div class="bg-slate-50 p-4 rounded-xl border border-slate-100">
							<label class="block text-xs font-medium text-slate-400">Adresse Email</label>
							<a href="mailto:{{ candidat.mail }}" class="mt-1 block text-sm font-semibold text-indigo-600 hover:underline break-all">
								{{ candidat.mail }}
							</a>
						</div>
					</div>

					<div>
						<h2 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4">Expérience</h2>
						<div class="bg-slate-50 p-4 rounded-xl border border-slate-100">
							<label class="block text-xs font-medium text-slate-400">Années d'expérience</label>
							<p class="mt-1 text-sm font-semibold text-slate-800">{{ candidat.experience }}
								ans</p>
						</div>
					</div>
				</div>

				<hr class="border-slate-100">

				<div>
					<h2 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">Description du profil</h2>
					<div class="prose prose-sm max-w-none bg-slate-50/50 p-4 rounded-xl border border-dashed border-slate-200">
						<p class="text-sm text-slate-600 leading-relaxed whitespace-pre-line">
							{{ candidat.description|default('Aucune description fournie.') }}
						</p>
					</div>
				</div>

			</div>
		</div>
	</div>
	{{ include ('_partials/_footer.html.twig')}}
{% endblock %}
