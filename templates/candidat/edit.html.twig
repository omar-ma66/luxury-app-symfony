{% extends 'base.html.twig' %}

{% block title %}Modifier le profil Candidat
{% endblock %}

{% block body %}

	<style>
		body {
			background-image: url('{{asset("assets/img/bg2.jpg")}}');
			background-position: center;
			background-size: cover;
			background-repeat: no-repeat;
			background-attachment: fixed;
		}
	</style>


	{{ include ('_partials/_header.html.twig')}}


	<script src="https://cdn.tailwindcss.com"></script>

	<div class="max-w-4xl mx-auto px-4 py-8 antialiased text-gray-800">

		<div class="mb-6">
			<a href="{{ path('app_candidat_index') }}" class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-slate-800 transition-colors duration-200">
				<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewbox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
				</svg>
				Retour à la liste
			</a>
		</div>

		<div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden mb-6">

			<div class="p-6 sm:p-8 bg-slate-50 border-b border-slate-100">
				<h1 class="text-2xl font-bold text-slate-900 tracking-tight">Modifier le Profil</h1>
				<p class="text-sm text-slate-500 mt-1">Mettez à jour les critères, les coordonnées et les informations du candidat.</p>
			</div>

			{{ form_start(form) }}
			<div class="p-6 sm:p-8 space-y-8">

				{% if not form.vars.valid %}
					<div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm flex items-start gap-2">
						<svg class="w-5 h-5 text-red-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewbox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
						</svg>
						<div>
							<span class="font-semibold">Formulaire incomplet.</span>
							Veuillez vérifier les champs indiqués en anomalie ci-dessous.
						</div>
					</div>
				{% endif %}

				<div>
					<h2 class="text-xs font-bold text-indigo-600 uppercase tracking-wider mb-4">1. Identité & État Civil</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
						<div>
							{{ form_label(form.nom, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.nom) }}
							<div class="text-xs text-red-500 mt-1 font-medium">{{ form_errors(form.nom) }}</div>
						</div>
						<div>
							{{ form_label(form.prenom, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.prenom) }}
							<div class="text-xs text-red-500 mt-1 font-medium">{{ form_errors(form.prenom) }}</div>
						</div>
						<div>
							{{ form_label(form.genre, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.genre) }}
							<div class="text-xs text-red-500 mt-1 font-medium">{{ form_errors(form.genre) }}</div>
						</div>
						<div>
							{{ form_label(form.naissance, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.naissance) }}
							<div class="text-xs text-red-500 mt-1 font-medium">{{ form_errors(form.naissance) }}</div>
						</div>
						<div>
							{{ form_label(form.lieuNaissance, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.lieuNaissance) }}
							<div class="text-xs text-red-500 mt-1 font-medium">{{ form_errors(form.lieuNaissance) }}</div>
						</div>
						<div>
							{{ form_label(form.nationalite, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.nationalite) }}
							<div class="text-xs text-red-500 mt-1 font-medium">{{ form_errors(form.nationalite) }}</div>
						</div>
					</div>
				</div>

				<hr class="border-slate-100">

				<div>
					<h2 class="text-xs font-bold text-indigo-600 uppercase tracking-wider mb-4">2. Coordonnées & Adresse</h2>
					<div class="grid grid-cols-1 md:grid-cols-3 gap-5">
						<div class="md:col-span-3">
							{{ form_label(form.mail, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.mail) }}
							<div class="text-xs text-red-500 mt-1 font-medium">{{ form_errors(form.mail) }}</div>
						</div>
						<div class="md:col-span-2">
							{{ form_label(form.adresse, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.adresse) }}
							<div class="text-xs text-red-500 mt-1 font-medium">{{ form_errors(form.adresse) }}</div>
						</div>
						<div>
							{{ form_label(form.pays, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.pays) }}
							<div class="text-xs text-red-500 mt-1 font-medium">{{ form_errors(form.pays) }}</div>
						</div>
					</div>
				</div>

				<hr class="border-slate-100">

				<div>
					<h2 class="text-xs font-bold text-indigo-600 uppercase tracking-wider mb-4">3. Spécifications du Profil</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
						<div>
							{{ form_label(form.jobCategorie, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.jobCategorie) }}
							<div class="text-xs text-red-500 mt-1 font-medium">{{ form_errors(form.jobCategorie) }}</div>
						</div>
						<div>
							{{ form_label(form.experience, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
							{{ form_widget(form.experience) }}
							<div class="text-xs text-red-500 mt-1 font-medium">{{ form_errors(form.experience) }}</div>
						</div>
					</div>
					<div>
						{{ form_label(form.description, null, {'label_attr': {'class': 'block text-xs font-semibold text-slate-500 uppercase tracking-wide'}}) }}
						{{ form_widget(form.description) }}
						<div class="text-xs text-red-500 mt-1 font-medium">{{ form_errors(form.description) }}</div>
					</div>
				</div>

				<div class="pt-5 border-t border-slate-100 flex items-center justify-end gap-3">
					<a href="{{ path('app_candidat_index') }}" class="px-5 py-2.5 border border-slate-200 rounded-xl text-sm font-semibold text-slate-600 bg-white hover:bg-slate-50 transition-all duration-150">
						Annuler
					</a>
					<button type="submit" class="px-6 py-2.5 border border-transparent rounded-xl text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 shadow-sm transition-all duration-150">
						Mettre à jour le profil
					</button>
				</div>

			</div>
			{{ form_end(form) }}
		</div>

		<div class="flex justify-center pt-4">
			<form method="post" action="{{ path('app_candidat_delete', {'id': candidat.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer définitivement ce profil ?');" class="w-full max-w-xs">
				<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ candidat.id) }}">
				<button type="submit" class="w-full inline-flex items-center justify-center px-4 py-2.5 border border-red-200 rounded-xl text-sm font-semibold text-red-600 bg-red-50/30 hover:bg-red-50 hover:text-red-700 transition-all duration-200 shadow-sm">
					<svg class="w-4 h-4 mr-2 text-red-500" fill="none" stroke="currentColor" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
					</svg>
					Supprimer le profil candidat
				</button>
			</form>
		</div>

	</div>
	{{ include ('_partials/_footer.html.twig')}}
{% endblock %}
