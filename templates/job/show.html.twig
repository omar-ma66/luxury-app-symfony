{# {% extends 'base.html.twig' %}

{% block title %}Job{% endblock %}

{% block body %}
    <h1>Job</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ job.id }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ job.description }}</td>
            </tr>
            <tr>
                <th>Active</th>
                <td>{{ job.active ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Notes</th>
                <td>{{ job.notes }}</td>
            </tr>
            <tr>
                <th>Intitule</th>
                <td>{{ job.intitule }}</td>
            </tr>
            <tr>
                <th>Type</th>
                <td>{{ job.type }}</td>
            </tr>
            <tr>
                <th>Categorie</th>
                <td>{{ job.categorie }}</td>
            </tr>
            <tr>
                <th>Creation</th>
                <td>{{ job.creation ? job.creation|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_job_index') }}">back to list</a>

    <a href="{{ path('app_job_edit', {'id': job.id}) }}">edit</a>

    {{ include('job/_delete_form.html.twig') }}
{% endblock %} #}
{% extends 'base.html.twig' %}

{% block title %}Détails du Job - {{ job.intitule }}{% endblock %}

{% block body %}

<style>
body{
    background-image:url('{{asset("assets/img/bg1.jpg")}}');
    background-position:center;
    background-size:cover;
    background-repeat:no-repeat;
    background-attachment: fixed; 
} 

</style>

{{ include ('_partials/_header.html.twig')}}

<div class="max-w-3xl mx-auto px-4 py-20">

    {# Bouton Retour discret au-dessus de la carte #}
    <div class="mb-6">
        <a class="group inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 hover:text-slate-800 transition-colors duration-200" 
           href="{{ path('app_job_index') }}">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transition-transform group-hover:-translate-x-0.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
            Retour à la liste
        </a>
    </div>

    {# Conteneur principal sous forme de Carte #}
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        
        {# En-tête de la carte #}
        <div class="p-6 md:p-8 border-b border-slate-100 flex flex-col md:flex-row md:items-center md:justify-between gap-4 bg-slate-50/50">
            <div>
                <span class="text-xs font-semibold uppercase tracking-wider text-slate-400">Fiche Job #{{ job.id }}</span>
                <h1 class="text-2xl font-bold text-slate-900 mt-0.5">{{ job.intitule }}</h1>
            </div>
            
            {# Badge de statut (Active) #}
            <div>
                {% if job.active %}
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-200">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                        Actif
                    </span>
                {% else %}
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-600 border border-slate-200">
                        <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
                        Inactif
                    </span>
                {% endif %}
            </div>
        </div>

        {# Corps de la carte (Informations) #}
        <div class="p-6 md:p-8 space-y-6">
            
            {# Grille d'informations secondaires #}
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                    <span class="block text-xs font-medium text-slate-400 uppercase tracking-wider">Type</span>
                    <span class="mt-1 block text-sm font-semibold text-slate-700 bg-slate-100 px-2.5 py-1 rounded-md inline-block">{{ job.type }}</span>
                </div>
                <div>
                    <span class="block text-xs font-medium text-slate-400 uppercase tracking-wider">Catégorie</span>
                    <span class="mt-1 block text-sm font-medium text-slate-800">{{ job.categorie }}</span>
                </div>
                <div>
                    <span class="block text-xs font-medium text-slate-400 uppercase tracking-wider">Date de création</span>
                    <span class="mt-1 block text-sm font-medium text-slate-600">
                        {{ job.creation ? job.creation|date('d/m/Y H:i') : 'N/A' }}
                    </span>
                </div>
            </div>

            <hr class="border-slate-100" />

            {# Section Description #}
            <div>
                <span class="block text-xs font-medium text-slate-400 uppercase tracking-wider mb-2">Description</span>
                <div class="text-sm text-slate-700 leading-relaxed bg-slate-50 p-4 rounded-xl border border-slate-100 whitespace-pre-line">
                    {{ job.description|default('Aucune description fournie.') }}
                </div>
            </div>

            {# Section Notes #}
            {% if job.notes %}
                <div>
                    <span class="block text-xs font-medium text-slate-400 uppercase tracking-wider mb-2">Notes internes</span>
                    <div class="text-sm text-slate-600 italic bg-amber-50/50 border border-amber-100 p-4 rounded-xl">
                        {{ job.notes }}
                    </div>
                </div>
            {% endif %}

        </div>

        {# Pied de la carte (Actions : Modifier & Supprimer) #}
        <div class="p-6 bg-slate-50 border-t border-slate-100 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            
            {# Le formulaire de suppression à gauche #}
            <div class="order-2 sm:order-1 ">
                {{ include('job/_delete_form.html.twig') }}
            </div>

            {# Le bouton d'édition à droite #}
            <div class="order-1 sm:order-2 flex justify-end">
                <a class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm rounded-lg shadow-sm transition-colors duration-200" 
                   href="{{ path('app_job_edit', {'id': job.id}) }}">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                    </svg>
                    Modifier le job
                </a>
            </div>

        </div>

    </div>
</div>

{{ include ('_partials/_footer.html.twig')}}
{% endblock %}