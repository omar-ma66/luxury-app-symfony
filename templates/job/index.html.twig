{% extends 'base.html.twig' %}

{% block title %}Job index{% endblock %}

{% block body %}
    <h1>Job index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Description</th>
                <th>Active</th>
                <th>Notes</th>
                <th>Intitule</th>
                <th>Type</th>
                <th>Categorie</th>
                <th>Creation</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for job in jobs %}
            <tr>
                <td>{{ job.id }}</td>
                <td>{{ job.description }}</td>
                <td>{{ job.active ? 'Yes' : 'No' }}</td>
                <td>{{ job.notes }}</td>
                <td>{{ job.intitule }}</td>
                <td>{{ job.type }}</td>
                <td>{{ job.categorie }}</td>
                <td>{{ job.creation ? job.creation|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a href="{{ path('app_job_show', {'id': job.id}) }}">show</a>
                    <a href="{{ path('app_job_edit', {'id': job.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="9">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_job_new') }}">Create new</a>
{% endblock %}
